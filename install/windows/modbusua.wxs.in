<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" 
           Name="${CN_APP_LNAME}" 
           Language="1033" 
           Version="${CN_APP_VERSION}.0" 
           Manufacturer="${CN_APP_VENDOR}" 
           UpgradeCode="A1B2C3D4-E5F6-4A5B-9C8D-7E6F5A4B3C2D">
    
    <Package InstallerVersion="200" 
             Compressed="yes" 
             InstallScope="perMachine" 
             Description="${CN_APP_DESC}"
             Comments="${CN_APP_LNAME} Service Installer"
             Manufacturer="${CN_APP_VENDOR}" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <UIRef Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <!-- License Configuration -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
    
    <!-- Add/Remove Programs Properties -->
    <!-- <Property Id="ARPPRODUCTICON" Value="ApplicationIcon" /> -->
    <!-- <Property Id="ARPURLINFOABOUT" Value="https://github.com/serhmarch/modbusua" /> -->
    <!-- <Property Id="ARPNOREPAIR" Value="yes" Secure="yes" /> -->
    <!-- <Property Id="ARPNOMODIFY" Value="yes" Secure="yes" /> -->
    <!-- <Property Id="ARPHELPLINK" Value="https://github.com/serhmarch/modbusua/issues" /> -->
    <!-- <Property Id="ARPCONTACT" Value="${CN_APP_VENDOR}" /> -->
    <!--
    <WixVariable Id="WixUIExclamationIco" Value="modbusua.ico" />
    <WixVariable Id="WixUIInfoIco" Value="modbusua.ico" />
    <WixVariable Id="WixUINewIco" Value="modbusua.ico" />
    <WixVariable Id="WixUIUpIco" Value="modbusua.ico" />
    -->
    <!-- Define installation directory -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="${CN_APP_NAME}">
            <Directory Id="confFolder" Name="conf"/>
            <Directory Id="docFolder" Name="doc"/>
            <Directory Id="logFolder" Name="log"/>
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder" />
      <Directory Id="DesktopFolder" />
    </Directory>

    <!-- Application Icon -->
    <!-- <Icon Id="ApplicationIcon" SourceFile="${CN_APP_NAME}.exe" /> -->

    <!-- Define features -->
    <Feature Id="ProductFeature" Title="${CN_APP_LNAME}" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

  </Product>

  <!-- Components -->
  <Fragment>
    <ComponentGroup Id="ProductComponents">
      <!-- Main exe file with Windows Service -->
      <Component Id="cmpProjectExecutable" Guid="B1A2C3D4-E5F6-4A5B-9C8D-7E6F5A4B3C2E" Directory="INSTALLFOLDER">
        <RemoveFile Id="RemoveOldExe" Name="${CN_APP_NAME}.exe" On="install" />
        <File Id="ProjectExe" 
              Source="${CN_APP_NAME}.exe" 
              KeyPath="yes" 
              Checksum="yes" />
        
        <!-- Windows Service Installation -->
        <ServiceInstall Id="ProjectService"
                        Type="ownProcess"
                        Name="${CN_APP_NAME}"
                        DisplayName="${CN_APP_NAME}"
                        Description="${CN_APP_DESC}"
                        Start="demand"
                        Account="LocalSystem"
                        ErrorControl="normal"
                        Interactive="no" />
        
        <!-- Service Control (Start/Stop) -->
        <!-- <Service Control Start="install" />  was disabled -->
        <ServiceControl Id="ProjectServiceControl"
                        Name="${CN_APP_NAME}"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>

      <!-- Service install/uninstall script -->
      <Component Id="cmpServiceInstallBatScript" Guid="FC463803-9A8A-4E6C-B03C-F8C52ADC5485" Directory="INSTALLFOLDER">
        <RemoveFile Id="RemoveOldBatScript" Name="${CN_APP_NAME}service.bat" On="install" />
        <File Id="ServiceBatScript" Source="${CN_APP_NAME}service.bat" />        
      </Component>

      <!-- Config file in conf subfolder -->
      <Component Id="cmpProjectConfig" Guid="C1B2A3D4-E5F6-4A5B-9C8D-7E6F5A4B3C2F" Directory="confFolder">
        <File Id="ProjectConf" 
              Source="conf/${CN_APP_CONF}" 
              KeyPath="yes" />
      </Component>

      <!-- Help file in doc subfolder -->
      <Component Id="cmpProjectHelp" Guid="D1C2B3A4-E5F6-4A5B-9C8D-7E6F5A4B3C20" Directory="docFolder">
        <RemoveFile Id="RemoveOldHelp" Name="*" On="install" />
        <CreateFolder />
        <File Id="ProjectChm" 
              Source="doc/${CN_APP_NAME}.chm" 
              KeyPath="yes" />
      </Component>

      <!-- log folder -->
      <Component Id="cmpCreateLogFolder" Guid="{64BFECF8-AF3B-4C47-8151-60BCA25A4246}" Directory="logFolder">
        <CreateFolder />
      </Component>

    </ComponentGroup>
  </Fragment>
</Wix>