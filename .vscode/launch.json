            "cwd": "${env:USERPROFILE}/tmp",
            "console": "externalTerminal",
            "visualizerFile": "c:\\Users\\march\\AppData\\Roaming\\Code\\User\\workspaceStorage\\f496642b10b95a3f76bd51853428bf62\\tonka3000.qtvsctools\\qt.natvis.xml",
            "args": ["--file", "c:/Users/march/Dropbox/PRJ/modbusua/examples/modbusua.conf"],
            "environment": [
                {
                    "name": "PATH",
                    "value": "${env:PATH};c:/Qt/5.15.2/msvc2019_64/bin" //${command:qt-cpp.kitDirectory}${/}bin"
